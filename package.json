{
  "name": "inflation",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome format . --write",
    "check": "biome check . --write",
    "postinstall": "node scripts/postinstall.js",
    "routes:generate": "tsr generate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "playwright:install": "playwright install",
    "docker-preview": "docker compose up --build preview -d && node -e \"console.log('\\n\\u279C  Production preview available at http://localhost:8080\\n')\"",
    "setup-ui": "echo y | pnpm dlx shadcn@latest init --yes -b base -p nova --no-reinstall && pnpm dlx shadcn@latest add button card input label badge table"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@playwright/test": "latest",
    "@tailwindcss/vite": "latest",
    "@tanstack/router-cli": "latest",
    "@tanstack/router-plugin": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "@vitest/ui": "latest",
    "happy-dom": "latest",
    "lefthook": "latest",
    "tailwindcss": "latest",
    "tailwindcss-animate": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "vitest-axe": "latest"
  }
}
